# ── Supabase ──────────────────────────────────────────────────────────────
# Dapatkan dari: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Catatan:
# - NEXT_PUBLIC_ prefix agar bisa diakses di browser (aman untuk anon key)
# - Service role key JANGAN di-expose ke frontend
# - Copy file ini ke .env.local dan isi nilainya
